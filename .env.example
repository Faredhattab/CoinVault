# =============================================================================
# CoinVault Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values from `supabase start` output
# WARNING: Never commit .env file to git! It contains sensitive credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,ar

# Supabase (Frontend - Public Keys Only!)
# Get these from: supabase start
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-start

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Supabase (Backend - Includes Admin Keys!)
# Get these from: supabase start
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-publishable-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_STORAGE_URL=http://127.0.0.1:54321/storage/v1/s3

# -----------------------------------------------------------------------------
# Authentication & Session Management
# -----------------------------------------------------------------------------
# Session timeout in days (sliding window)
SESSION_TIMEOUT_DAYS=7

# Maximum concurrent sessions per user
MAX_CONCURRENT_SESSIONS=3

# Rate limiting for login attempts
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15

# -----------------------------------------------------------------------------
# Database Seeding (Initial Admin Account)
# -----------------------------------------------------------------------------
# These credentials are used by backend/src/coinvault/db/seeds/run_seeds.py
# WARNING: Change these in production!
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=SecurePassword123!

# =============================================================================
# Setup Instructions:
# =============================================================================
# 1. Run: supabase start
# 2. Copy the anon key to SUPABASE_ANON_KEY and NEXT_PUBLIC_SUPABASE_ANON_KEY
# 3. Copy the service_role key to SUPABASE_SERVICE_ROLE_KEY
# 4. Run: cd backend/src && python -m coinvault.db.seeds.run_seeds
# 5. Start backend: cd backend && python -m uvicorn coinvault.main:app --app-dir src --reload
# 6. Start frontend: cd frontend && npm run dev
#
# See SETUP-GUIDE.md for detailed instructions.
# =============================================================================
